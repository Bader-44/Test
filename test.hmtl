<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>HSE Safety Management System | Daily Inspection Reports</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #f0f2f5; font-family: 'Inter', sans-serif; padding: 20px; color: #1e293b; }
        .container { max-width: 1400px; margin: 0 auto; }
        .header-card { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-radius: 28px; padding: 30px; margin-bottom: 30px; color: white; box-shadow: 0 20px 35px -12px rgba(0,0,0,0.2); }
        .observation-card { background: white; border-radius: 28px; margin-bottom: 28px; box-shadow: 0 8px 20px rgba(0,0,0,0.05); overflow: hidden; border: 1px solid rgba(0,0,0,0.05); }
        .card-body { padding: 24px; }
        .form-row { margin-bottom: 20px; }
        .form-row label { display: block; font-weight: 700; margin-bottom: 8px; color: #334155; font-size: 13px; }
        .form-row input, .form-row textarea, .form-row select { width: 100%; padding: 10px 14px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 13px; }
        .action-bar { display: flex; flex-wrap: wrap; gap: 16px; margin: 32px 0 24px; justify-content: center; }
        .btn-primary { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border: none; padding: 12px 28px; border-radius: 60px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 10px; text-decoration: none; font-size: 14px; }
        .btn-excel { background: linear-gradient(135deg, #107c41, #185c37); }
        .btn-danger { background: linear-gradient(135deg, #ef4444, #dc2626); }
        .images-grid { display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0; }
        .image-card { flex: 1; min-width: 250px; background: #f8fafc; padding: 15px; border-radius: 20px; border: 1px solid #e2e8f0; }
        .image-preview-box { background: white; border-radius: 15px; min-height: 150px; border: 2px dashed #cbd5e1; display: flex; flex-wrap: wrap; gap: 10px; padding: 10px; margin-bottom: 10px; }
        .img-thumb { position: relative; width: 80px; height: 80px; border-radius: 10px; overflow: hidden; }
        .img-thumb img { width: 100%; height: 100%; object-fit: cover; }
    </style>
</head>
<body>
<div class="container">
    <div class="header-card">
        <h1><i class="fas fa-shield-alt"></i> HSE Safety Management System</h1>
        <p>Hazard Documentation & Auto-Excel Export</p>
    </div>

    <div id="observationsList"></div>

    <div class="action-bar">
        <button class="btn-primary" onclick="addNewObservation()"><i class="fas fa-plus-circle"></i> New Observation</button>
        <button class="btn-primary btn-excel" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> Export to Excel</button>
        <button class="btn-primary btn-danger" onclick="clearAllData()"><i class="fas fa-trash-alt"></i> Clear All</button>
    </div>
</div>

<script>
    const SITES_LIST = ["Mega WH", "RUH WH74", "SLS WH", "Salasa Head Office", "DS01 Al Munsiyah", "DS02 Narjis", "DS03 Al Rawbi", "JED", "DMM"];
    let observations = JSON.parse(localStorage.getItem('hse_data') || '[]');

    function saveData() { localStorage.setItem('hse_data', JSON.stringify(observations)); render(); }

    function addNewObservation() {
        observations.push({ id: Date.now(), site: SITES_LIST[0], visitDate: new Date().toISOString().split('T')[0], problemDesc: '', potentialRisks: '', correctiveActions: '', beforeImages: [], afterImages: [] });
        saveData();
    }

    function exportToExcel() {
        if (observations.length === 0) { alert("No data to export!"); return; }
        const data = observations.map((o, i) => ({
            "No": i + 1, "Site": o.site, "Date": o.visitDate, "Description": o.problemDesc, "Risks": o.potentialRisks, "Actions": o.correctiveActions, "Photos": (o.beforeImages.length + o.afterImages.length)
        }));
        const ws = XLSX.utils.json_to_sheet(data);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "HSE Report");
        XLSX.writeFile(wb, `HSE_Report_${new Date().toLocaleDateString()}.xlsx`);
    }

    function render() {
        const list = document.getElementById('observationsList');
        if (observations.length === 0) { list.innerHTML = '<div style="text-align:center; padding:50px; color:#64748b;">No observations yet. Click "New Observation".</div>'; return; }
        list.innerHTML = observations.map((obs, i) => `
            <div class="observation-card">
                <div class="card-body">
                    <div class="form-row"><label>Site Location</label>
                        <select onchange="update(${obs.id}, 'site', this.value)">${SITES_LIST.map(s => `<option value="${s}" ${obs.site===s?'selected':''}>${s}</option>`).join('')}</select>
                    </div>
                    <div class="form-row"><label>Description</label>
                        <input type="text" value="${obs.problemDesc}" onchange="update(${obs.id}, 'problemDesc', this.value)" placeholder="Hazard description...">
                    </div>
                    <div class="form-row"><label>Corrective Actions</label>
                        <textarea onchange="update(${obs.id}, 'correctiveActions', this.value)">${obs.correctiveActions}</textarea>
                    </div>
                    <button style="color:red; background:none; border:none; cursor:pointer;" onclick="del(${obs.id})">Delete Report #${i+1}</button>
                </div>
            </div>
        `).join('');
    }

    function update(id, field, val) { const o = observations.find(x => x.id === id); if(o) o[field] = val; saveData(); }
    function del(id) { if(confirm('Delete?')) { observations = observations.filter(x => x.id !== id); saveData(); } }
    function clearAllData() { if(confirm('Clear all?')) { observations = []; saveData(); } }

    render();
</script>
</body>
</html>
